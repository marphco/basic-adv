{
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/index\\.php(.*)",
      "status": 410
    },
    {
      "src": "/portfolio/(.*)",
      "status": 410
    },
    {
      "src": "/(dashboard|login)(/.*)?",
      "headers": { "X-Robots-Tag": "noindex, nofollow" },
      "continue": true
    },
    {
      "src": "/p/(.*)",
      "headers": { "X-Robots-Tag": "noindex, nofollow" },
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
